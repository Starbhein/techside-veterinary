generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  cliente
  medico
  admin
}

enum UsuarioStatus {
  activo
  pendiente
  inactivo
}

model MxDivision {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String   @db.VarChar(120)
  clave       String   @unique @db.VarChar(20)
  direccion   String?  @db.VarChar(255)
  telefono    String?  @db.VarChar(15)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  personas    Persona[]
  @@map("mx_divisiones")
}

model Persona {
  id                  String   @id @default(uuid()) @db.Uuid
  nombreCompleto      String   @map("nombre_completo") @db.VarChar(200)
  telefono            String   @db.VarChar(15)
  telefonoSecundario  String?  @map("telefono_secundario") @db.VarChar(15)
  calle               String   @db.VarChar(200)
  numExterior         String?  @map("num_exterior") @db.VarChar(20)
  numInterior         String?  @map("num_interior") @db.VarChar(20)
  sucursalId          String   @map("sucursal_id") @db.Uuid
  proofAddressId      String?  @map("proof_address_id") @db.Uuid
  proofIdId           String?  @map("proof_id_id") @db.Uuid
  sucursal            MxDivision @relation(fields: [sucursalId], references: [id])
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  usuario             Usuario?
  @@index([telefono])
  @@index([sucursalId])
  @@map("persona")
}

model Usuario {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique @db.VarChar(255)
  telefono      String           @unique @db.VarChar(15)
  passwordHash  String           @map("password_hash") @db.Text
  rol           Rol
  status        UsuarioStatus    @default(pendiente)
  personaId     String           @unique @map("persona_id") @db.Uuid
  persona       Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  emailVerifications  EmailVerificationToken[]
  passwordResets      PasswordResetToken[]
  @@index([email])
  @@index([telefono])
  @@index([rol])
  @@map("usuario")
}

model Archivo {
  id            String   @id @default(uuid()) @db.Uuid
  url           String   @db.Text
  nombreArchivo String   @map("nombre_archivo") @db.VarChar(255)
  mime          String   @db.VarChar(100)
  tamano        Int
  subidoEn      DateTime @default(now()) @map("subido_en")
  @@map("archivos")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([usuarioId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([usuarioId])
  @@map("password_reset_tokens")
}

model Especie {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  razas     Raza[]
  @@map("especies")
}

model Raza {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @db.VarChar(120)
  especieId String   @map("especie_id") @db.Uuid
  especie   Especie  @relation(fields: [especieId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([especieId, nombre])
  @@map("razas")
}

model Color {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("colores")
}

model TipoPelo {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("tipos_pelo")
}

model PatronPelo {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("patrones_pelo")
}

model Comportamiento {
  id            String   @id @default(uuid()) @db.Uuid
  nombre        String   @unique @db.VarChar(120)
  requiereBozal Boolean  @default(false) @map("requiere_bozal")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  @@map("comportamientos")
}

model CatalogoAlergia {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("catalogo_alergias")
}
