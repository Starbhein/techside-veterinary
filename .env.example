# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto del servidor NestJS
PORT=3000

# URL de conexión a PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/vetec

# Secreto para firmar JWTs — mínimo 32 caracteres
JWT_SECRET=change-me-to-at-least-32-characters-long

# Tiempo de expiración del JWT (ej: 24h, 7d)
JWT_EXPIRES_IN=24h

# Rondas de salt para bcrypt (mínimo 10, recomendado 12)
BCRYPT_ROUNDS=12

# === Email Verification (nuevo) ===

# API key de Resend para envío de correos
# Obtén una en https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de conexión a Redis (para la cola de Bull)
# Local: redis://localhost:6379
# Docker: redis://host.docker.internal:6379
REDIS_URL=redis://localhost:6379

# URL base del backend para construir links de verificación
BACKEND_BASE_URL=http://localhost:3000

# (Opcional) URLs del frontend para redirigir después de verificar email
# Si no se configuran, se devuelve JSON en su lugar
FRONTEND_CONFIRMATION_SUCCESS_URL=
FRONTEND_CONFIRMATION_ERROR_URL=
